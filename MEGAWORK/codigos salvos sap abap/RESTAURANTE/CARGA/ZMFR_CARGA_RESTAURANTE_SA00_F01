    " Parte da tsabela preenchida internamente
    ls_cliente-dtcriacao    = sy-datum.
    ls_cliente-hrcriacao    = sy-uzeit.
    ls_cliente-usrcriacao   = sy-uname.

    APPEND ls_cliente TO gt_cliente.

  ENDLOOP.

