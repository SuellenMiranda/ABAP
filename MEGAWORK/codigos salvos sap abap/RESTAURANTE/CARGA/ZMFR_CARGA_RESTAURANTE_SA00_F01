  DATA: ls_cliente LIKE LINE OF gt_cliente.

  LOOP AT gt_template INTO DATA(ls_template).

    " Parte da tabela preenchida externamente
    ls_cliente-cpf          = |{ ls_template-col_a ALPHA = IN }|.
    ls_cliente-idcliente    = ls_template-col_b.
    ls_cliente-nome         = ls_template-col_c.
    ls_cliente-dtnascimento = |{ ls_template-col_d+6(4) }{ ls_template-col_d+3(2) }{ ls_template-col_d(2) }|.
