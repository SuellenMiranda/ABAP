*
*  IF lt_result[] IS NOT INITAL.
*  "// TRANSFERINDO O VALOR DA LINHA PARA UMA ESTRUTURA INTERNA
*  LOOP AT gt_cliente INTO DATA(ls_cliente).
*    ls_cliente-hralteracao = sy-uzeit.
*    READ TABLE lt_result WITH KEY cpf = ls_cliente-cpf idcliente = lls_cliente-idcliente TRANSPORTING NO FIELDS.
*    IF sy-subrc EQ 0.
*      ls_cliente-hralteracao = sy-uzeit.
*      MODIFY gt_cliente FROM ls_cliente.
*    ENDIF.
*  ENDLOOP.
*
*  "// PONTEIRO DIRETO PRA ÁREA E ALTERANDO DIRETAMENTE
*  LOOP AT gt_cliente ASSIGNING FIELD-SYMBOL(<fs_cliente>).
*    <fs_cliente>-hralteracao = sy-uzeit.
