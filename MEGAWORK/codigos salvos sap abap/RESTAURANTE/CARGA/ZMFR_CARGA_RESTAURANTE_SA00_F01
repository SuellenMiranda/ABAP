*&---------------------------------------------------------------------*
*& Form save_data
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM save_data .

  "INSERT

  "UPDATE

  "MODIFY ******* INSERT + UPDATE

  DATA: ls_rel_out LIKE LINE OF gt_rel_output.

  LOOP AT gt_cliente INTO DATA(ls_cliente).

    MODIFY zmft_cli_sa00 FROM ls_cliente. "/(zmft_cli_sa00).
    IF sy-subrc EQ 0. "// Comando efetuado com sucesso!
      ls_rel_out-status   = 'S'.
      ls_rel_out-cpf      = ls_cliente-cpf.
      ls_rel_out-mensagem = 'Sucesso ao inserir/modificar registro!'.

    ELSE. "// Tem algo muito errado nesse registro
      ls_rel_out-status   = 'E'.
      ls_rel_out-cpf      = ls_cliente-cpf.
      ls_rel_out-mensagem = 'Erro ao inserir/modificar registro!'.

    ENDIF.

    APPEND ls_rel_out TO gt_rel_output.

  ENDLOOP.

ENDFORM.
*&---------------------------------------------------------------------*
*& Form display_info
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM display_info .

  gt_fieldcat = VALUE slis_t_fieldcat_alv(
        ( fieldname = 'STATUS' outputlen = 1 reptext_ddic = 'Status' )
        ( fieldname = 'CPF' outputlen = 14 reptext_ddic = 'CPF' edit_mask = '___.___.___-__' )
        ( fieldname = 'MENSAGEM' outputlen = 40 reptext_ddic = 'Mensagem' ) ).

  CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'
    EXPORTING
      i_callback_program     = sy-repid "Nome do programa em execução
      i_callback_top_of_page = 'F_TOP_OF_PAGE' "Qual o from responsavel por montar o nosso cabeçalho
      it_fieldcat            = gt_fieldcat "Layout do Grid
    TABLES
      t_outtab               = gt_rel_output "De onde vem a informação renderizada no grid
    EXCEPTIONS
      program_error          = 1
      OTHERS                 = 2.

ENDFORM.
FORM f_top_of_page.

***=> alv Header declarations
  DATA: lt_header TYPE slis_t_listheader.

  lt_header = VALUE slis_t_listheader( ( typ = 'H' info = 'Carga de Clientes' )
                                       ( typ = 'A' info = 'MegaFood' )
                                       ( typ = 'A' info = |Total de registros: { lines( gt_cliente ) } | )
                                       ( typ = 'A' info = |Usuários: { sy-uname } | )
                                       ( typ = 'A' info = |DATA: { sy-datum+6(2) }/{ sy-datum+4(2) }/{ sy-datum(4) } | )
                                       ( typ = 'A' info = |Hora: { sy-uzeit+0(2) }:{ sy-uzeit+2(2) }:{ sy-uzeit+4(2) } | ) ).

  CALL FUNCTION 'REUSE_ALV_COMMENTARY_WRITE'
    EXPORTING
      it_list_commentary = lt_header
      i_logo             = 'LOGOMFOOD'.

ENDFORM.